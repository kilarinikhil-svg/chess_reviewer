# Browser origin allowed by FastAPI CORS middleware.
CORS_ORIGIN=https://your-frontend-domain.vercel.app

# Backend root (/) redirect target.
FRONTEND_URL=https://your-frontend-domain.vercel.app

# Engine/runtime defaults.
STOCKFISH_THREADS=2
STOCKFISH_POOL_SIZE=4
STOCKFISH_HASH_MB=512
ANALYSIS_TIMEOUT_SECONDS=45
DEEP_JOB_WORKERS=1
SESSION_TTL_SECONDS=21600

# Chess.com fetch behavior.
CHESSCOM_SSL_VERIFY=true
CHESSCOM_CA_BUNDLE=
CHESSCOM_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0 Safari/537.36

# Optional coach LLM integration (Vertex AI).
COACH_USE_LLM=false
GOOGLE_APPLICATION_CREDENTIALS_B64=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
COACH_LLM_MODEL=gemini-2.0-flash-001
COACH_LLM_MAX_OUTPUT_TOKENS=2048

# Optional move-analysis LLM integration (Vertex AI).
MOVE_USE_LLM=false
MOVE_LLM_MODEL=gemini-2.5-flash
MOVE_LLM_MAX_OUTPUT_TOKENS=2048
MOVE_LLM_TIMEOUT_SECONDS=30
MOVE_BATCH_CHUNK_SIZE=4
MOVE_LLM_MAX_CONCURRENCY=2
MOVE_LLM_PROMPT_VERSION=v1
